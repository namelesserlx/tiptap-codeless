{
    "name": "tiptap-codeless",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "description": "Production-ready Tiptap extensions for code blocks, drag handles, slash menus, and file uploads with React, TypeScript, and built-in i18n",
    "keywords": [
        "tiptap",
        "tiptap-extension",
        "editor",
        "extensions",
        "react",
        "typescript",
        "rich-text-editor",
        "code-block",
        "drag-handle",
        "slash-command",
        "file-upload",
        "mermaid",
        "lowlight"
    ],
    "author": "namelesserlx (https://github.com/namelesserlx)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/namelesserlx/tiptap-codeless"
    },
    "homepage": "https://github.com/namelesserlx/tiptap-codeless#readme",
    "bugs": {
        "url": "https://github.com/namelesserlx/tiptap-codeless/issues"
    },
    "engines": {
        "node": ">=22.12.0",
        "pnpm": ">=8.0.0"
    },
    "scripts": {
        "dev": "pnpm --filter \"./packages/**\" --parallel dev",
        "build": "pnpm --filter \"./packages/**\" build",
        "build:core": "pnpm --filter \"@tiptap-codeless/core\" build",
        "build:extensions": "pnpm --filter \"./packages/extension-*\" build",
        "test": "vitest",
        "test:run": "vitest run",
        "test:watch": "vitest --watch",
        "test:e2e": "pnpm build && playwright test",
        "type-check": "pnpm build:core && pnpm --filter \"./packages/**\" type-check",
        "lint": "eslint .",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
        "prepush": "pnpm format && pnpm lint && pnpm type-check && pnpm build",
        "clean": "pnpm --filter \"./packages/**\" clean",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.1",
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@types/node": "^24.10.2",
        "@typescript-eslint/eslint-plugin": "^8.49.0",
        "@typescript-eslint/parser": "^8.49.0",
        "@vitejs/plugin-react": "^4.3.4",
        "dts-bundle-generator": "^9.5.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^27.0.1",
        "postcss-discard-comments": "^7.0.5",
        "prettier": "^3.7.4",
        "react": "^19.2.1",
        "react-dom": "^19.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.2.7",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.4"
    }
}
