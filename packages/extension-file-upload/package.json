{
    "name": "@tiptap-codeless/extension-file-upload",
    "version": "1.0.0",
    "description": "Tiptap file upload extension with drag and drop, paste, image resize, preview cards, pluggable storage, and built-in i18n",
    "keywords": [
        "tiptap",
        "editor",
        "upload",
        "image",
        "video",
        "file",
        "react",
        "file-upload",
        "image-resize",
        "i18n"
    ],
    "author": "namelesserlx (https://github.com/namelesserlx)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/namelesserlx/tiptap-codeless",
        "directory": "packages/extension-file-upload"
    },
    "homepage": "https://namelesserlx.github.io/tiptap-codeless/file-upload/",
    "bugs": {
        "url": "https://github.com/namelesserlx/tiptap-codeless/issues"
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        },
        "./dist/index.css": "./dist/index.css",
        "./styles": "./dist/index.css"
    },
    "files": [
        "dist",
        "README.md",
        "README.zh-CN.md"
    ],
    "scripts": {
        "dev": "tsc && vite build --watch",
        "build": "rm -rf dist && vite build && node ../../scripts/bundle-dts.mjs --project tsconfig.json --entry src/index.ts --output dist/index.d.ts --external-import @tiptap-codeless/core --append-declaration src/types/tiptap-file-upload.ts",
        "type-check": "tsc --noEmit",
        "lint": "eslint src test",
        "clean": "rm -rf dist",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
    },
    "dependencies": {
        "@tiptap-codeless/core": "workspace:*",
        "@tiptap/core": "^3.22.4",
        "@tiptap/pm": "^3.22.4",
        "@tiptap/react": "^3.22.4",
        "classnames": "^2.5.1"
    },
    "devDependencies": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.3.4",
        "react": "^19.2.1",
        "react-dom": "^19.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.2.7"
    },
    "peerDependencies": {
        "@tiptap/core": ">=3.0.0",
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    }
}
